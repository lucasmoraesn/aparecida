# ─────────────────────────────────────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
PRODUCTION_DOMAIN=https://aparecidadonortesp.com.br
FRONTEND_URL=https://aparecidadonortesp.com.br

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE — Banco de dados
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_key_aqui

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE — Pagamentos e assinaturas
# Dashboard: https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─────────────────────────────────────────────────────────────────────────────
# RESEND — E-mail transacional
#
# 1. Obtenha sua chave API em https://resend.com/api-keys
# 2. Verifique seu domínio em https://resend.com/domains
# 3. Use o formato "Nome <email@dominio.com>" no RESEND_FROM
#
# Documentação: https://resend.com/docs
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_seu_api_key_aqui

# Endereço de envio verificado no Resend (formato: "Nome <email@dominio.com>")
RESEND_FROM=Explore Aparecida <noreply@aparecidadonortesp.com.br>

# E-mail do administrador (recebe notificações internas de novas assinaturas)
ADMIN_EMAIL=admin@aparecidadonortesp.com.br
